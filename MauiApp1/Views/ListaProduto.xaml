<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.ListaProduto"
             Title="Minhas Compras">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Somar" Clicked="ToolbarItem_Clicked_1" />
        <ToolbarItem Text="Adicionar" Clicked="ToolbarItem_Clicked" />
    </ContentPage.ToolbarItems>

    <VerticalStackLayout>
        <SearchBar x:Name="txt_search"
                   Placeholder="Busca de Produtos"
                   TextChanged="txt_search_TextChanged"/>

        <CollectionView x:Name="lst_produtos"
                        SelectionMode="Single"
                        SelectionChanged="lst_produtos_SelectionChanged">
            <CollectionView.Header>
                <Grid ColumnDefinitions="*, *, *, *, *" Padding="10">
                    <Label Grid.Column="0" Text="ID" FontAttributes="Bold"/>
                    <Label Grid.Column="1" Text="Descrição" FontAttributes="Bold"/>
                    <Label Grid.Column="2" Text="Preço" FontAttributes="Bold"/>
                    <Label Grid.Column="3" Text="Qnt" FontAttributes="Bold"/>
                    <Label Grid.Column="4" Text="Total" FontAttributes="Bold"/>
                </Grid>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*, *, *, *, *" Padding="10">
                        <Label Grid.Column="0" Text="{Binding Id}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding Descricao}" VerticalOptions="Center"/>
                        <Label Grid.Column="2" Text="{Binding Preco}" VerticalOptions="Center"/>
                        <Label Grid.Column="3" Text="{Binding Quantidade}" VerticalOptions="Center"/>
                        <Label Grid.Column="4" Text="{Binding Total}" VerticalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>